LOCAL_COMPANY_PORT=8789
LOCAL_COMPANY_HOST=127.0.0.1
LOCAL_COMPANY_DATA_DIR=./data

CODEX_RUNNER=codex-cli
CODEX_CLI_BIN=codex
CODEX_PM_MODEL=gpt-5.5
CODEX_WORKER_MODEL=gpt-5.5
CODEX_REVIEW_MODEL=gpt-5.5
CODEX_TIMEOUT_MS=600000
CODEX_EXEC_USES_SKIP_GIT_REPO_CHECK=true

RUN_MAX_PARALLEL_WORKERS=3
RUN_MAX_ATTEMPTS_PER_TASK=2
RUN_MAX_TOTAL_MINUTES=120
